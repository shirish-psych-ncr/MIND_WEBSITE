# Logs and temp files
*.log
*.tmp
*.swp
*.swo
*.bak
*.~
*.pyc
*.pyo
*.pyd
*.class

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
Icon?
VolumeIcon.icns

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
