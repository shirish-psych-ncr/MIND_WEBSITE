```gitignore
# Build artifacts
dist/
build/
*.o
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.egg-info/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.manifest
*.spec

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```