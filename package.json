{
  "name": "mind-grace-neuropsychiatric-clinic-website",
  "version": "1.0.0",
  "description": "High-accessibility static website for Mind Grace Neuropsychiatric Clinic",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "audit:a11y": "pa11y ./dist/*.html",
    "audit:lhci": "lhci collect --staticDistDir=./dist",
    "build:css": "postcss src/css/main.css -o dist/css/main.min.css",
    "build:critical": "node scripts/critical.js",
    "lint:js": "eslint src/js/**/*.js",
    "lint:css": "stylelint src/css/**/*.css",
    "format": "biome format . --write && prettier --write \"**/*.{html,md}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@plausible-analytics/tracker": "0.4.5",
    "@preact/signals": "2.9.3",
    "alpinejs": "3.15.12",
    "animejs": "4.5.0",
    "blurhash": "2.0.5",
    "colord": "2.9.3",
    "dompurify": "3.4.12",
    "exifreader": "4.41.0",
    "fitty": "2.4.2",
    "focus-trap": "8.2.2",
    "fuse.js": "7.4.2",
    "headroom": "0.0.1",
    "htmx": "0.0.2",
    "iconify-icon": "3.0.2",
    "isomorphic-image-size": "1.0.6",
    "motion": "12.42.2",
    "nanoid": "5.1.16",
    "navigo": "8.11.1",
    "petite-vue": "0.4.1",
    "preact": "10.29.5",
    "quicklink": "3.0.1",
    "swup": "4.9.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/cli": "4.12.1",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "0.15.1",
    "@modelcontextprotocol/server-memory": "2026.7.4",
    "@neplex/vectorizer": "0.1.0",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "axe-core": "4.12.1",
    "backstopjs": "6.3.25",
    "biome": "0.2.2",
    "critical": "8.0.0",
    "cssnano": "8.0.2",
    "depcheck": "1.4.7",
    "diff-match-patch": "1.0.5",
    "eslint": "10.7.0",
    "focus-visible": "5.2.1",
    "globals": "17.7.0",
    "html-validate": "10.0.0",
    "htmllint": "0.8.0",
    "imagemagick": "0.1.3",
    "inline-css": "4.0.3",
    "knip": "5.88.1",
    "node-html-parser": "9.0.0",
    "pa11y": "9.1.1",
    "parse-css": "0.1.0",
    "playwright": "1.61.1",
    "postcss-cli": "11.0.1",
    "postcss-safe-parser": "7.0.1",
    "prettier": "3.9.5",
    "puppeteer-core": "24.43.1",
    "purgecss": "8.0.0",
    "rehype": "13.0.2",
    "rehype-cli": "12.0.1",
    "rehype-parse": "9.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "sharp": "0.35.3",
    "sharp-ico": "0.1.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "svgo": "4.0.2",
    "terser": "5.49.0",
    "treeify": "1.1.0",
    "ts-morph": "28.0.0",
    "ui-ux-pro-max-cli": "2.10.2",
    "vitest": "3.2.7",
    "zx": "8.8.5"
  },
  "overrides": {
    "tmp": "^0.2.3",
    "uuid": "^11.1.1"
  }
}