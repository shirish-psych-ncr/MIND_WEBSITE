---
// src/layouts/BaseLayout.astro
import ErrorBoundary from '../components/ErrorBoundary.astro';
import Nav from '../components/Nav.astro'; // Optional: If you extracted Nav into a component

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = "Mind Grace Clinic | Psychiatrist in Greater Noida",
  description = "Expert psychiatric care, counseling, and child development services in Greater Noida. Dr. Anita Sharma provides compassionate mental health support for anxiety, depression, ADHD, and more.",
  ogImage = "/res/Mind_Grace_Clinic_Logo_Full.png", // Ensure this path exists in public/
  canonical = "",
  noindex = false
} = Astro.props;

// Get the base path dynamically (e.g., "/MIND_WEBSITE/" or "/")
const base = import.meta.env.BASE_URL;

// Construct full URLs for SEO
const siteUrl = "https://shirish-psych-ncr.github.io";
const currentPath = Astro.url.pathname;
const finalCanonical = canonical || `${siteUrl}${base}${currentPath}`;
const finalOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${base}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en-IN" dir="ltr" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=0.5, user-scalable=yes, viewport-fit=cover" />
  
  <!-- Theme Color -->
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#671B50" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#4A1438" />
  <meta name="color-scheme" content="light dark" />

  <!-- SEO Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={finalCanonical} />
  
  <!-- Robots -->
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={finalCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={finalOgImage} />
  <meta property="og:image:secure_url" content={finalOgImage} />
  <meta property="og:image:alt" content="Mind Grace Clinic Logo" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="675" />
  <meta property="og:site_name" content="Mind Grace Clinic" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={finalCanonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={finalOgImage} />
  <meta name="twitter:image:alt" content="Mind Grace Clinic Logo" />

  <!-- Favicon & PWA -->
  <link rel="icon" type="image/svg+xml" href={`${base}res/Mind_Grace_Clinic_Logo_Pink.svg`} />
  <link rel="apple-touch-icon" href={`${base}res/Mind_Grace_Clinic_Logo_Pink.svg`} />
  <link rel="manifest" href={`${base}site.webmanifest`} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Mind Grace" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap" rel="stylesheet" />

  <!-- Stylesheets -->
  <link rel="stylesheet" href={`${base}styles/base.css`} />
  <link rel="stylesheet" href={`${base}styles/layout.css`} />
  <link rel="stylesheet" href={`${base}styles/components.css`} />
  <link rel="stylesheet" href={`${base}styles/utilities.css`} />
  <link rel="stylesheet" href={`${base}styles/animations.css`} />

  <!-- Critical Inline CSS -->
  <style>
    /* Prevent FOUC (Flash of Unstyled Content) */
    body {
      font-family: 'Manrope', sans-serif;
      opacity: 1;
      transition: opacity 0.3s ease-in-out;
    }
    .hero-content {
      opacity: 1;
    }
  </style>
</head>

<body>
  <!-- Skip Link for Accessibility -->
  <a href="#main-content" class="skip-link visually-hidden">Skip to main content</a>

  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="header-inner container">
      <a href={`${base}`} class="logo-link" aria-label="Mind Grace Clinic Home">
        <svg class="logo-svg" viewBox="0 0 900 873" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <use href={`${base}res/Mind_Grace_Clinic_Logo_Pink.svg#icon`} />
        </svg>
        <div>
          <div class="logo-text">Mind Grace Clinic</div>
          <div class="logo-tagline">Where You Come First</div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="desktop-nav" role="navigation" aria-label="Main navigation">
        <ul>
          <li><a href={`${base}about/`}>About</a></li>
          <li><a href={`${base}services/`}>Services</a></li>
          <li><a href={`${base}process/`}>Process</a></li>
          <li><a href={`${base}resources/`}>Resources</a></li>
          <li><a href={`${base}location/`}>Location</a></li>
          <li><a href={`${base}book/`} class="cta-button">Book Now</a></li>
        </ul>
      </nav>

      <!-- Mobile Nav Trigger -->
      <button class="mobile-nav-trigger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav-panel">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile Nav Overlay -->
  <div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>

  <!-- Mobile Nav Panel -->
  <nav class="mobile-nav-panel" id="mobile-nav-panel" role="navigation" aria-label="Mobile navigation" inert>
    <div class="mobile-nav-header">
      <h2>Menu</h2>
      <button class="close-mobile-menu" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="mobile-nav-content">
      <div class="mobile-nav-section">
        <div class="mobile-nav-section-title">Explore</div>
        <ul class="mobile-nav-list">
          <li><a href={`${base}about/`}>About Us</a></li>
          <li><a href={`${base}services/`}>Our Services</a></li>
          <li><a href={`${base}process/`}>What to Expect</a></li>
          <li><a href={`${base}location/`}>Find Us</a></li>
          <li><a href={`${base}contact/`}>Contact</a></li>
        </ul>
      </div>

      <div class="mobile-nav-section">
        <div class="mobile-nav-section-title">Resources & Tools</div>
        <ul class="mobile-nav-list">
          <li><a href={`${base}gallery/`}>Gallery</a></li>
          <li><a href={`${base}book/`}>Resource Book</a></li>
          <li><a href={`${base}resources/`}>Resources</a></li>
          <li><a href={`${base}faq/`}>FAQ</a></li>
        </ul>
      </div>

      <div class="mobile-nav-section">
        <div class="mobile-nav-section-title">Therapeutic Tools</div>
        <ul class="mobile-nav-list">
          <li><a href={`${base}guided-breathing/`}>Guided Breathing</a></li>
          <li><a href={`${base}butterfly-tapper/`}>Butterfly Tapper</a></li>
          <li><a href={`${base}eye-movement/`}>Eye Movement</a></li>
          <li><a href={`${base}hypnos-fractal/`}>Hypnotic Fractal</a></li>
          <li><a href={`${base}horizon-scan/`}>Horizon Scan</a></li>
          <li><a href={`${base}leaf-on-stream/`}>Leaf on Stream</a></li>
        </ul>
      </div>

      <div class="mobile-nav-section">
        <a href={`${base}book/`} class="cta-button">Book Appointment</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main id="main-content" role="main">
    <ErrorBoundary>
      <slot />
    </ErrorBoundary>
  </main>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="footer-content container">
      <div class="footer-column">
        <h4>Clinic</h4>
        <ul>
          <li><a href={`${base}about/`}>About Dr. Sharma</a></li>
          <li><a href={`${base}services/`}>All Services</a></li>
          <li><a href={`${base}process/`}>What to Expect</a></li>
          <li><a href={`${base}gallery/`}>Gallery</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4>Support</h4>
        <ul>
          <li><a href={`${base}faq/`}>FAQ</a></li>
          <li><a href={`${base}contact/`}>Contact Us</a></li>
          <li><a href={`${base}emergency/`}>Emergency Help</a></li>
          <li><a href={`${base}consent/`}>Patient Consent</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4>Resources</h4>
        <ul>
          <li><a href={`${base}book/`}>Resource Book</a></li>
          <li><a href={`${base}resources/`}>Self-Help Tools</a></li>
          <li><a href={`${base}conditions/`}>Conditions</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4>Legal</h4>
        <ul>
          <li><a href={`${base}privacy/`}>Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="disclaimer">
        Disclaimer: Information on this website is for educational purposes only and does not replace professional medical advice.
        Always consult a qualified healthcare provider for diagnosis and treatment. In crisis, call emergency services immediately.
      </p>
      <p class="footer-copyright">
        © {new Date().getFullYear()} Mind Grace Clinic, Greater Noida. All rights reserved.
      </p>
    </div>
  </footer>

  <!-- Global Scripts -->
  <script is:inline src={`${base}scripts/main.js`}></script>
</body>
</html>