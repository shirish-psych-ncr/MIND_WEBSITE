---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}
const { href, variant = 'primary', class: className = '' } = Astro.props;
---
{href ? (
  <a href={href} class={`btn btn-${variant} ${className}`}><slot /></a>
) : (
  <button class={`btn btn-${variant} ${className}`}><slot /></button>
)}
