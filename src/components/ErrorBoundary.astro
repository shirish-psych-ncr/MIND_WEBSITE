---
// ErrorBoundary component for graceful error handling
interface Props {
  fallback?: string;
}

const { fallback = 'Something went wrong. Please try refreshing the page.' } = Astro.props;
---

<div class="error-boundary" data-error-boundary>
  <slot />
  
  <script is:inline>
    // Simple client-side error boundary using window.onerror
    window.addEventListener('error', function(event) {
      const boundary = document.querySelector('[data-error-boundary]');
      if (boundary) {
        console.error('Error caught by boundary:', event.message);
        // Could show fallback UI here if needed
      }
    });
    
    window.addEventListener('unhandledrejection', function(event) {
      const boundary = document.querySelector('[data-error-boundary]');
      if (boundary) {
        console.error('Unhandled promise rejection:', event.reason);
      }
    });
  </script>
</div>

<style>
  .error-boundary {
    min-height: inherit;
  }
</style>
