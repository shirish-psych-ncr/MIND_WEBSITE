---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<div class="shell stack">

    <!-- HERO -->
    <section class="surface panel">
      <h1>Inside the clinic</h1>
      <p class="lead">
        A calm, structured space designed for clarity, comfort, and focused care — for both adults and children.
      </p>
    </section>

    <!-- EXTERIOR + ENTRY -->
    <section class="surface panel">
      <h2>Getting here</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/Location_street_view_distance.jpg" alt="Clinic exterior view" />
          <figcaption>Outside view of the clinic</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/mind-grace-entry-n-reception.jpg" alt="Entry and reception" />
          <figcaption>Entrance and reception area</figcaption>
        </figure>
      </div>
    </section>

    <!-- CONSULTATION FLOW -->
    <section class="surface panel">
      <h2>Adult consultation spaces</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/mind-grace-consultation-room.jpg" alt="Consultation room" />
          <figcaption>Consultation room — focused, private discussions</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/mind-grace-therapy-room.jpg" alt="Therapy room" />
          <figcaption>Therapy space for structured sessions</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/mind-grace-small-room.jpg" alt="Additional clinic room" />
          <figcaption>Additional clinical space</figcaption>
        </figure>
      </div>
    </section>

    <!-- AASHA INTRO -->
    <section class="surface-soft panel">
      <h2>Aasha Early Intervention</h2>

      <p>
        Dedicated child development spaces designed for engagement, learning, and structured therapeutic work.
      </p>
    </section>

    <!-- SPEECH THERAPY -->
    <section class="surface panel">
      <h2>Speech & language development</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/aasha-speech-hindi-varnmala.jpg" alt="Hindi varnmala learning setup used for child speech and language support" />
          <figcaption>Hindi varnmala learning setup</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-speech-english-alphabets.jpg" alt="English alphabet learning board used in child language sessions" />
          <figcaption>English alphabet learning board</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-speech-english-alphabets-closeup.jpg" alt="Close-up language learning aids used in Aasha speech support sessions" />
          <figcaption>Close-up learning aids</figcaption>
        </figure>
      </div>
    </section>

    <!-- SPECIAL EDUCATION -->
    <section class="surface panel">
      <h2>Special education & cognitive development</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/aasha-special-ed-fruit-sort.jpg" alt="Fruit sorting activity used for structured child learning and special education support" />
          <figcaption>Sorting and categorisation tasks</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-special-ed-fruit-sort-closeup.jpg" alt="Close-up of sorting materials used for cognitive learning activities" />
          <figcaption>Close-up structured activity</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-special-ed-jigsaw.jpg" alt="Jigsaw activity used for problem-solving and cognitive development support" />
          <figcaption>Jigsaw for problem-solving skills</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-special-ed-abacus.jpg" alt="Abacus learning tool used for number sense and attention-building activities" />
          <figcaption>Abacus for number sense and focus</figcaption>
        </figure>
      </div>
    </section>

    <!-- OCCUPATIONAL THERAPY -->
    <section class="surface panel">
      <h2>Occupational therapy & sensory work</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/aasha-occupational-therapy-junglejim-trampoline.jpg" alt="Movement-based occupational therapy setup with trampoline for sensory regulation" />
          <figcaption>Movement-based regulation (trampoline)</figcaption>
        </figure>

        <figure class="image-card">
          <img src="./res/aasha-occupational-therapy-lycra-junglejim.jpg" alt="Lycra-based occupational therapy support used for sensory integration work" />
          <figcaption>Sensory integration with lycra support</figcaption>
        </figure>
      </div>
    </section>

    <!-- DOCTOR -->
    <section class="surface panel">
      <h2>Clinical leadership</h2>

      <div class="image-grid">
        <figure class="image-card">
          <img src="./res/Dr_Anita_Sharma_Personal_Photo.jpg" alt="Professional portrait of Dr Anita Sharma" />
          <figcaption>Dr Anita Sharma — Consultant Psychiatrist</figcaption>
        </figure>
      </div>
    </section>
</BaseLayout>
