---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- Hero Section -->
    <section class="hero hero-small bg-warm">
      <div class="container hero-container">
        <div class="hero-content">
          <span class="section-badge">Community Initiative</span>
          <h1>Aasha: Bringing Hope to Communities</h1>
          <p class="lead">Early intervention, community empowerment, and mental health awareness for children and families across Greater Noida.</p>
        </div>
        <div class="hero-image">
          <img src="/images/aasha-hero.svg" alt="Children and families in community support" onerror="this.style.display='none'"/>
        </div>
      </div>
    </section>

    <!-- Our Story Section -->
    <section class="section">
      <div class="container">
        <div class="story-block text-center">
          <h2>Our Mission</h2>
          <p><strong>"Aasha"</strong> means hope in Hindi. Our initiative was born from a simple belief: every child deserves the opportunity to thrive, regardless of their developmental challenges or family circumstances.</p>
          <p>We work at the intersection of clinical expertise and community outreach, providing early intervention services, parent education, and awareness programs that reach families who might otherwise lack access to mental health support.</p>
          <p>Through school partnerships, government collaborations, and grassroots workshops, we're building a more informed, supportive community where children with developmental differences are understood, accepted, and empowered.</p>
        </div>
      </div>
    </section>

    <!-- Impact Stats Section -->
    <section class="section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <h2>Our Impact So Far</h2>
          <p class="section-desc">Making a difference in the lives of children and families</p>
        </div>
        
        <div class="impact-stats">
          <div class="stat-item">
            <span class="stat-number" data-target="500">500+</span>
            <span class="stat-label">Workshops Conducted</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="10000">10000+</span>
            <span class="stat-label">Lives Touched</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="50">50+</span>
            <span class="stat-label">School Partnerships</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="2000">2000+</span>
            <span class="stat-label">Parents Trained</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Programs Section -->
    <section class="section">
      <div class="container">
        <div class="section-header text-center">
          <h2>Our Programs</h2>
          <p class="section-desc">Comprehensive support for children, parents, and educators</p>
        </div>
        
        <div class="program-grid">
          <div class="program-card">
            <h3>School Workshops</h3>
            <p>Interactive sessions for teachers and students on recognizing early signs of developmental delays, ADHD, autism, and learning disabilities. We provide practical classroom strategies and foster inclusive environments.</p>
          </div>
          
          <div class="program-card">
            <h3>Parent Guidance Sessions</h3>
            <p>Empowering parents with knowledge and skills to support their child's development at home. Topics include behavior management, communication techniques, and navigating the healthcare and education systems.</p>
          </div>
          
          <div class="program-card">
            <h3>Rural Outreach Camps</h3>
            <p>Free screening camps in underserved areas, providing early identification of developmental concerns and connecting families with appropriate resources and government schemes.</p>
          </div>
          
          <div class="program-card">
            <h3>Teacher Training Programs</h3>
            <p>Comprehensive training for educators on inclusive education practices, individualized education plans (IEPs), and supporting diverse learners in mainstream classrooms.</p>
          </div>
          
          <div class="program-card">
            <h3>Community Awareness Drives</h3>
            <p>Public campaigns to reduce stigma around mental health and developmental disorders, promoting early intervention and acceptance in the broader community.</p>
          </div>
          
          <div class="program-card">
            <h3>Support Groups</h3>
            <p>Facilitated peer support groups for parents of children with similar challenges, providing emotional support, resource sharing, and a sense of community.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Get Involved Section -->
    <section class="section bg-warm">
      <div class="container">
        <div class="section-header text-center">
          <h2>Get Involved</h2>
          <p class="section-desc">Join us in making a difference</p>
        </div>
        
        <div class="get-involved-grid">
          <div class="involve-card">
            <h3>Volunteer</h3>
            <p>Share your time and skills</p>
          </div>
          <div class="involve-card">
            <h3>Partner With Us</h3>
            <p>Schools & Organizations</p>
          </div>
          <div class="involve-card">
            <h3>Support Our Cause</h3>
            <p>Donate or Sponsor</p>
          </div>
        </div>
        
        <div class="text-center" style="margin-top: 2rem;">
          <a href="/contact.html" class="btn btn-primary btn-large">Contact Us to Learn More</a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section-cta">
      <div class="container text-center">
        <h2>Need Support for Your Child?</h2>
        <p class="lead">Early intervention can make a significant difference. Let's work together.</p>
        <div class="cta-group">
          <a href="/book.html" class="btn btn-primary btn-large">Book an Assessment</a>
          <a href="/services.html" class="btn btn-outline btn-large">View Services</a>
        </div>
      </div>
    </section>
</BaseLayout>
