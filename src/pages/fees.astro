---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- HERO SECTION -->
    <section class="hero hero-small">
      <div class="hero-inner">
        <div class="hero-content">
          <span class="section-badge">Transparent Pricing</span>
          <h1>Fees, payments, and what your visit includes</h1>
          <p class="lead">
            We believe in complete transparency about costs. Here's a clear breakdown of our fees 
            and payment options to help you plan your care without surprises.
          </p>
        </div>
      </div>
    </section>

    <!-- PRICING TABLES SECTION -->
    <section class="section">
      <div class="shell">
        <div class="section-header">
          <h2>Consultation & Session Fees</h2>
          <p>Standard rates for all services as of 2025</p>
        </div>

        <div class="pricing-grid">
          <!-- Psychiatric Consultation -->
          <article class="price-card">
            <div class="price-header">
              <h3>Psychiatric Consultation</h3>
              <p class="price-subtitle">Initial assessment with Dr. Anita Sharma</p>
            </div>
            <div class="price-amount">
              <span class="currency">₹</span>
              <span class="amount">900</span>
            </div>
            <ul class="price-features">
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                45-minute comprehensive session
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Detailed evaluation and diagnosis
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Personalized treatment plan
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Medication management if needed
              </li>
            </ul>
            <div class="price-footer">
              <a href="./book.html" class="button button-primary button-full">Book Consultation</a>
            </div>
          </article>

          <!-- Follow-up Consultation -->
          <article class="price-card">
            <div class="price-header">
              <h3>Follow-up Consultation</h3>
              <p class="price-subtitle">Ongoing care and medication review</p>
            </div>
            <div class="price-amount">
              <span class="currency">₹</span>
              <span class="amount">700</span>
            </div>
            <ul class="price-features">
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                30-minute follow-up session
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Medication adjustment and monitoring
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Progress evaluation
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Continued support and guidance
              </li>
            </ul>
            <div class="price-footer">
              <a href="./book.html" class="button button-primary button-full">Book Follow-up</a>
            </div>
          </article>

          <!-- Therapy Sessions -->
          <article class="price-card featured">
            <div class="price-badge">Most Popular</div>
            <div class="price-header">
              <h3>Therapy Sessions (Aasha)</h3>
              <p class="price-subtitle">Individual psychotherapy with trained therapists</p>
            </div>
            <div class="price-amount">
              <span class="currency">₹</span>
              <span class="amount">500–700</span>
            </div>
            <ul class="price-features">
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                45–60 minute therapy session
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                CBT, supportive therapy, or counseling
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Fee varies by therapist and format
              </li>
              <li>
                <svg class="icon icon-sm check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                Sliding scale available for students
              </li>
            </ul>
            <div class="price-footer">
              <a href="./book.html" class="button button-primary button-full">Book Therapy</a>
            </div>
          </article>
        </div>

        <!-- Assessment Services -->
        <div class="section-header" style="margin-top: 4rem;">
          <h2>Psychological Assessments & Testing</h2>
          <p>Comprehensive evaluations for accurate diagnosis</p>
        </div>

        <div class="notice-box notice-info">
          <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <strong>Assessment fees vary based on scope</strong>
            <p style="margin-top: 0.5rem;">
              Psychological testing is quoted after an initial screening to determine the appropriate 
              assessment battery. Common assessments include IQ testing, ADHD evaluation, autism spectrum 
              assessment, and personality inventories. Typical range: ₹2,000 – ₹8,000 depending on complexity.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PAYMENT OPTIONS SECTION -->
    <section class="section section-alt">
      <div class="shell">
        <div class="section-header">
          <h2>Payment Methods & Policies</h2>
          <p>Flexible payment options to suit your needs</p>
        </div>

        <div class="features-grid">
          <!-- Cash Payment -->
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h3>Cash Payment</h3>
            <p>Accepted at the clinic during your visit. Please carry exact change when possible.</p>
          </article>

          <!-- UPI Payment -->
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3>UPI Payment</h3>
            <p>Scan QR code at clinic or use UPI ID. Instant confirmation and digital receipt.</p>
          </article>

          <!-- Bank Transfer -->
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
              </svg>
            </div>
            <h3>NEFT / IMPS</h3>
            <p>Bank transfer details provided upon booking. Share transaction ID for confirmation.</p>
          </article>

          <!-- Invoice -->
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <h3>Detailed Invoices</h3>
            <p>Itemized receipts provided for insurance reimbursement or tax documentation.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- INSURANCE SECTION -->
    <section class="section">
      <div class="shell">
        <div class="section-header">
          <h2>Insurance & Reimbursement</h2>
          <p>Mental health coverage information</p>
        </div>

        <div class="notice-box notice-info">
          <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <strong>Mental Healthcare Act, 2017 Compliance</strong>
            <p style="margin-top: 0.5rem;">
              As per Indian law, mental health conditions must be covered by insurance providers 
              just like physical health conditions. We provide detailed invoices and medical 
              documentation to support your reimbursement claims.
            </p>
          </div>
        </div>

        <div class="services-grid" style="margin-top: 2rem;">
          <article class="service-card">
            <div class="service-icon">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3>Government Insurance</h3>
            <p>CGHS, ECHS, and other government schemes accepted with proper documentation.</p>
          </article>

          <article class="service-card">
            <div class="service-icon">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3>Private Insurance</h3>
            <p>Major providers including Star Health, HDFC Ergo, ICICI Lombard, and more.</p>
          </article>

          <article class="service-card">
            <div class="service-icon">
              <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3>Corporate Plans</h3>
            <p>Many employer-provided health plans include mental health coverage. Check with HR.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- CANCELLATION POLICY -->
    <section class="section section-alt">
      <div class="shell">
        <div class="section-header">
          <h2>Cancellation & Rescheduling Policy</h2>
          <p>We understand life happens — here's our flexible approach</p>
        </div>

        <div class="notice-box notice-warning">
          <svg class="icon icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <h3>24-Hour Notice Requested</h3>
            <p>
              To avoid charges, please cancel or reschedule at least 24 hours before your appointment. 
              Late cancellations (less than 24 hours) may incur a 50% fee. No-shows will be charged 
              the full consultation fee. We maintain this policy to respect the time of our clinicians 
              and other patients waiting for appointments.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="section-cta">
      <div class="shell">
        <div class="section-cta-center">
          <h2>Ready to begin your journey?</h2>
          <p>Taking the first step towards better mental health is brave. We're here to support you.</p>
          <div class="cta-group">
            <a href="./book.html" class="button button-large button-primary">Book Your Appointment</a>
            <a href="./contact.html" class="button button-large button-outline">Have Questions?</a>
            <a href="./process.html" class="button button-large button-ghost">Learn About Our Process</a>
          </div>
        </div>
      </div>
    </section>
</BaseLayout>
