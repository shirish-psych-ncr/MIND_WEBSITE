---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Guided Breathing Tool | Mind Grace Clinic" description="A guided breathing tool to reduce anxiety, calm panic, and support sleep using clinically grounded techniques.">
  <link rel="stylesheet" href="/styles/tools-breathing.css" />
  
  <div class="shell stack">
    <section class="surface panel">
      <h1>Guided breathing for anxiety and calm</h1>
      <p class="lead">
        Use this when your body feels tense, your mind is racing, or sleep feels difficult.
      </p>
    </section>
    
    <!-- TOOL -->
    <!-- Mind Grace Guided Breathing Tool -->
    <div id="breath-app" class="app-container">
    
      <!-- MENU -->
      <div id="menu" class="view">
        <h2 class="title">Guided Breathing</h2>
    
        <p class="lead-mini">
          A simple way to calm the body when anxiety, overthinking, or restlessness builds up.
        </p>
    
        <div class="setting">
          <label>Choose focus</label>
          <select id="tech-sel">
            <option value="box">Focus & Grounding (Box Breathing)</option>
            <option value="relax">Sleep & Deep Relaxation (4-7-8)</option>
            <option value="calm">Panic & Rapid Calm (7-11)</option>
          </select>
        </div>
    
        <div class="setting">
          <label>Duration</label>
          <div class="chips">
            <button class="chip active" data-m="1">1m</button>
            <button class="chip" data-m="2">2m</button>
            <button class="chip" data-m="5">5m</button>
            <button class="chip" data-m="10">10m</button>
          </div>
        </div>
    
        <button id="start-btn" class="main-btn">Start</button>
      </div>
    
      <!-- SESSION -->
      <div id="session" class="view hidden">
        <div id="timer" class="timer">01:00</div>
    
        <div class="stage">
          <div id="circle" class="circle">
            <span id="breath-label">Prepare</span>
          </div>
        </div>
    
        <button id="stop-btn" class="text-btn">End session</button>
      </div>
    
      <!-- END -->
      <div id="end" class="view hidden">
        <div class="end-content">
          <div class="star">✧</div>
          <h2>Notice the shift</h2>
          <p>Your body has slowed down. Let it stay that way.</p>
    
          <div class="cta-row">
            <button id="reset-btn" class="main-btn">Repeat</button>
            <a href="/resources" class="button-ghost">Learn more</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/scripts/tools-breathing.js"></script>
</BaseLayout>
