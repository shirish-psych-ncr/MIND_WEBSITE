---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- Hero Section -->
    <section class="hero hero-small">
      <div class="container hero-container">
        <div class="hero-content">
          <span class="section-badge">Our Philosophy</span>
          <h1>A Holistic Approach to Mental Health</h1>
          <p class="lead">We believe in treating the whole person—not just symptoms. Our biopsychosocial model integrates biological, psychological, and social factors for comprehensive care.</p>
        </div>
        <div class="hero-image">
          <img src="/images/approach-hero.svg" alt="Illustration representing holistic mental health care" onerror="this.style.display='none'"/>
        </div>
      </div>
    </section>

    <!-- The Three Pillars Section -->
    <section class="section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-badge">The Biopsychosocial Model</span>
          <h2>Three Pillars of Care</h2>
          <p class="section-desc">Mental health is influenced by multiple interconnected factors. We address all three dimensions for lasting wellness.</p>
        </div>
        
        <div class="pillar-grid">
          <!-- Biological Pillar -->
          <div class="pillar-card">
            <div class="pillar-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                <line x1="12" x2="12" y1="19" y2="22"/>
              </svg>
            </div>
            <h3>Biological</h3>
            <p>We examine genetic predispositions, neurochemistry, hormonal balance, sleep patterns, nutrition, and physical health conditions that may impact mental well-being.</p>
            <ul class="check-list">
              <li>Medication management when needed</li>
              <li>Sleep and lifestyle optimization</li>
              <li>Nutritional considerations</li>
              <li>Medical condition screening</li>
            </ul>
          </div>
          
          <!-- Psychological Pillar -->
          <div class="pillar-card">
            <div class="pillar-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                <line x1="9" x2="9.01" y1="9" y2="9"/>
                <line x1="15" x2="15.01" y1="9" y2="9"/>
              </svg>
            </div>
            <h3>Psychological</h3>
            <p>We explore thoughts, emotions, behaviors, past traumas, coping mechanisms, and personality factors that shape your mental health experience.</p>
            <ul class="check-list">
              <li>Evidence-based psychotherapy</li>
              <li>Trauma-informed care</li>
              <li>Cognitive-behavioral strategies</li>
              <li>Emotional regulation skills</li>
            </ul>
          </div>
          
          <!-- Social Pillar -->
          <div class="pillar-card">
            <div class="pillar-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3>Social</h3>
            <p>We consider relationships, family dynamics, work environment, cultural context, socioeconomic factors, and community support systems.</p>
            <ul class="check-list">
              <li>Family and couples therapy</li>
              <li>Work-life balance strategies</li>
              <li>Social skills development</li>
              <li>Community resource connection</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Integration Section -->
    <section class="section">
      <div class="container">
        <div class="section-header text-center">
          <h2>How We Integrate These Pillars</h2>
          <p class="section-desc">Every treatment plan is personalized, drawing from all three dimensions based on your unique needs.</p>
        </div>
        
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="step-number">01</span>
            </div>
            <div class="timeline-content">
              <h3>Comprehensive Assessment</h3>
              <p>We begin with a thorough evaluation covering medical history, psychological screening, and social context. This helps us understand which pillars need the most attention.</p>
            </div>
          </div>
          
          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="step-number">02</span>
            </div>
            <div class="timeline-content">
              <h3>Personalized Treatment Planning</h3>
              <p>Based on the assessment, we create a customized plan that may include medication, therapy, lifestyle changes, family involvement, or community resources—whatever combination serves you best.</p>
            </div>
          </div>
          
          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="step-number">03</span>
            </div>
            <div class="timeline-content">
              <h3>Ongoing Monitoring & Adjustment</h3>
              <p>Mental health is dynamic. We regularly review progress across all three pillars and adjust the treatment plan as needed to ensure continued improvement.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values Section -->
    <section class="section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <h2>Our Core Values</h2>
        </div>
        
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3>Compassionate Care</h3>
            <p>Every interaction is grounded in empathy, respect, and genuine concern for your well-being.</p>
          </div>
          
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
            <h3>Evidence-Based Practice</h3>
            <p>We use treatments proven effective by scientific research, combined with clinical expertise.</p>
          </div>
          
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h3>Strict Confidentiality</h3>
            <p>Your privacy is paramount. All sessions and records are kept completely confidential.</p>
          </div>
          
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" x2="12" y1="8" y2="12"/>
                <line x1="12" x2="12.01" y1="16" y2="16"/>
              </svg>
            </div>
            <h3>Cultural Sensitivity</h3>
            <p>We honor diverse backgrounds, beliefs, and values in our approach to care.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section-cta">
      <div class="container text-center">
        <h2>Ready to Experience Holistic Care?</h2>
        <p class="lead">Take the first step toward comprehensive mental wellness.</p>
        <div class="cta-group">
          <a href="/book.html" class="btn btn-primary btn-large">Book Your Consultation</a>
          <a href="/process.html" class="btn btn-outline btn-large">Learn About Our Process</a>
        </div>
      </div>
    </section>
</BaseLayout>
