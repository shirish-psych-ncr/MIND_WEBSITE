---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout>
<a class="skip-link" href="#content">Skip to Main Content</a>

<div class="progress"><div class="progress-bar" data-progress></div></div>

<div class="top-banner">
  In case of a medical emergency, call 112 or visit the nearest hospital.
</div>

<!-- HEADER -->
<header class="site-header">
  <div class="shell header-row">
    <a class="brand-wrap" href="/">
      <img class="logo" src="/res/Mind_Grace_Clinic_Logo.png" alt="Mind Grace Clinic logo" />
      <div>
        <p class="brand-kicker">Mind Grace Clinic</p>
        <p class="brand-name">Dr Anita Sharma MD</p>
      </div>
    </a>

    <nav class="nav">
      <a href="/about">About</a>
      <a href="/conditions">Conditions</a>
      <a href="/services">Services</a>
      <a href="/process">Process</a>
      <a href="/resources">Resources</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="header-actions">
      <a class="button-outline" href="tel:+919667863295">Call</a>
      <a class="button" href="/book">Book</a>
    </div>
  </div>
</header>

<!-- MAIN -->
<main id="content" class="section">
  <div class="shell">

    <div class="tool-container">
      <div class="tool-card">

        <!-- SETUP -->
        <div id="setup-view" class="view">
          <div style="font-size:2rem;">↔️</div>
          <h1>Lateral grounding</h1>
          <p>Keep your head still. Follow the moving light with your eyes only.</p>

          <div class="settings-box">
            <div class="label">Choose speed</div>
            <select id="speed-selector">
              <option value="3500">Gentle</option>
              <option value="2200" selected>Steady</option>
              <option value="1200">Fast</option>
            </select>

            <button class="start-btn" onclick="startTracking()">Start session</button>
          </div>
        </div>

        <!-- ACTIVE -->
        <div id="active-view" class="view hidden">
          <div class="track-container">
            <div class="track-line">
              <div id="orb" class="orb"></div>
            </div>
          </div>

          <button class="stop-btn" onclick="stopTracking()">End session</button>
        </div>

      </div>
    </div>

  </div>
</main>

<!-- FOOTER -->
<footer class="footer">
  <div class="shell footer-grid">
    <div>
      <h3>Mind Grace Clinic</h3>
      <p class="lead">Structured mental health care focused on real-life outcomes.</p>
  <a href="/resources" class="button-ghost">Learn more</a>
    </div>
  </div>
</footer>

<style is:inline>
:root {
  --bg: #070b14;
  --card-bg: #111827;
  --accent: #38bdf8;
  --text: #f1f5f9;
  --muted: #64748b;
}

.tool-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 40px 20px;
}

.tool-card {
  background: var(--card-bg);
  border-radius: 40px;
  padding: 40px 30px;
  text-align: center;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.view {
  width: 100%;
}

.hidden { display: none !important; }

h1 {
  font-weight: 300;
  font-size: 1.8rem;
  margin-bottom: 10px;
}

p {
  color: var(--muted);
  margin-bottom: 25px;
}

.track-container {
  width: 100%;
  padding: 60px 0;
  position: relative;
}

.track-line {
  width: 100%;
  height: 2px;
  background: rgba(255,255,255,0.08);
  position: relative;
}

.orb {
  width: 35px;
  height: 35px;
  background: var(--accent);
  border-radius: 50%;
  position: absolute;
  top: -16px;
  left: 0;
  box-shadow: 0 0 25px var(--accent);
}

.settings-box {
  max-width: 300px;
  margin: 0 auto;
}

.label {
  font-size: 0.7rem;
  text-transform: uppercase;
  color: var(--muted);
  letter-spacing: 2px;
  margin-bottom: 8px;
  text-align: left;
}

select {
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  border: 1px solid #1f2937;
  background: #1f2937;
  color: white;
  margin-bottom: 20px;
}

.start-btn {
  width: 100%;
  padding: 14px;
  border-radius: 14px;
  border: none;
  background: var(--text);
  color: var(--bg);
  font-weight: 600;
  cursor: pointer;
}

.stop-btn {
  margin-top: 30px;
  background: none;
  border: none;
  color: var(--muted);
  text-decoration: underline;
  cursor: pointer;
}
</style>

<script is:inline>
let moveInterval;
let currentDir = 'right';

function startTracking() {
  const speed = parseInt(document.getElementById('speed-selector').value);
  const orb = document.getElementById('orb');

  document.getElementById('setup-view').classList.add('hidden');
  document.getElementById('active-view').classList.remove('hidden');

  orb.style.transition = `left ${speed}ms ease-in-out`;

  setTimeout(() => {
    orb.style.left = 'calc(100% - ' + orb.offsetWidth + 'px)';
  }, 50);

  moveInterval = setInterval(() => {
    if (currentDir === 'right') {
      orb.style.left = '0%';
      currentDir = 'left';
    } else {
      orb.style.left = 'calc(100% - ' + orb.offsetWidth + 'px)';
      currentDir = 'right';
    }
  }, speed + 50);
}

function stopTracking() {
  clearInterval(moveInterval);

  document.getElementById('active-view').classList.add('hidden');
  document.getElementById('setup-view').classList.remove('hidden');

  const orb = document.getElementById('orb');
  orb.style.transition = 'none';
  orb.style.left = '0%';

  currentDir = 'right';
}
</script>
</BaseLayout>
