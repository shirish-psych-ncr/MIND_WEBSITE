---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- HERO SECTION -->
    <section class="hero-section hero-small">
      <div class="hero-content">
        <p class="hero-eyebrow">Get in Touch</p>
        <h1>Contact Mind Grace Clinic</h1>
        <p class="hero-lead">
          If you are planning a visit, asking a routine question, or ready to request an appointment,
          these are the quickest ways to reach the clinic.
        </p>
      </div>
    </section>

    <!-- EMERGENCY NOTICE -->
    <section class="section-padded bg-warning">
      <div class="container-narrow">
        <div class="alert alert-warning">
          <svg class="alert-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <div>
            <strong>Emergency Notice:</strong> For medical emergencies or crisis situations, call 112 immediately or go to the nearest hospital emergency room. This clinic does not provide emergency services.
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT INFO CARDS -->
    <section class="section-padded">
      <div class="container">
        <div class="contact-grid">
          
          <!-- Phone Card -->
          <div class="contact-card">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <h3>Phone</h3>
            <p class="contact-detail">
              <a href="tel:+919667863295">+91 96678 63295</a>
            </p>
            <p class="contact-meta">Call during clinic hours</p>
            <a href="tel:+919667863295" class="button-primary button-small">Call Now</a>
          </div>

          <!-- WhatsApp Card -->
          <div class="contact-card">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
              </svg>
            </div>
            <h3>WhatsApp</h3>
            <p class="contact-detail">
              <a href="https://wa.me/919667863295" target="_blank" rel="noopener">+91 96678 63295</a>
            </p>
            <p class="contact-meta">Quick responses for appointments</p>
            <a href="https://wa.me/919667863295" target="_blank" rel="noopener" class="button-primary button-small">Message Us</a>
          </div>

          <!-- Email Card -->
          <div class="contact-card">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <h3>Email</h3>
            <p class="contact-detail">
              <a href="mailto:dranitasharma86@gmail.com">dranitasharma86@gmail.com</a>
            </p>
            <p class="contact-meta">Response within 24-48 hours</p>
            <a href="mailto:dranitasharma86@gmail.com" class="button-primary button-small">Send Email</a>
          </div>

          <!-- Address Card -->
          <div class="contact-card">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3>Address</h3>
            <p class="contact-detail">
              J-123, Gamma-2,<br/>
              Greater Noida,<br/>
              Uttar Pradesh 201310
            </p>
            <p class="contact-meta">Clinic hours below</p>
            <a href="/location.html" class="button-outline button-small">Get Directions</a>
          </div>

          <!-- Hours Card -->
          <div class="contact-card">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3>Clinic Hours</h3>
            <p class="contact-detail">
              Monday to Saturday<br/>
              10:00 AM – 4:00 PM<br/>
              5:30 PM – 7:30 PM
            </p>
            <p class="contact-meta">Closed on Sundays</p>
            <a href="/book.html" class="button-outline button-small">Book Appointment</a>
          </div>

          <!-- Emergency Card -->
          <div class="contact-card contact-card-emergency">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <h3>Emergency</h3>
            <p class="contact-detail">
              For immediate help:<br/>
              <strong style="font-size: 1.25rem;">Call 112</strong>
            </p>
            <p class="contact-meta">Police, Fire, Medical</p>
            <a href="/emergency.html" class="button-outline button-small">Emergency Info</a>
          </div>

        </div>
      </div>
    </section>

    <!-- CONTACT FORM SECTION -->
    <section class="section-padded bg-soft">
      <div class="container-narrow">
        <div class="section-header-center">
          <span class="section-badge">Send a Message</span>
          <h2>Quick Inquiry Form</h2>
          <p class="section-intro">
            Have a routine question? Fill out this form and we'll get back to you within 24-48 hours.
            For appointments, please use our booking page or call directly.
          </p>
        </div>

        <form class="contact-form" action="#" method="POST" novalidate>
          <div class="form-grid">
            
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your full name"/>
            </div>

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="your.email@example.com"/>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+91 XXXXX XXXXX"/>
            </div>

            <div class="form-group">
              <label for="subject">Subject *</label>
              <select id="subject" name="subject" required>
                <option value="">Select a subject</option>
                <option value="appointment">Appointment Inquiry</option>
                <option value="services">Services Question</option>
                <option value="fees">Fees & Insurance</option>
                <option value="other">Other Question</option>
              </select>
            </div>

          </div>

          <div class="form-group">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message" rows="5" required placeholder="Please describe your inquiry..."></textarea>
          </div>

          <div class="form-group checkbox-group">
            <input type="checkbox" id="consent" name="consent" required/>
            <label for="consent">I agree to the <a href="/privacy.html">Privacy Policy</a> and consent to being contacted regarding my inquiry. *</label>
          </div>

          <div class="form-actions">
            <button type="submit" class="button-primary button-large">Send Message</button>
            <p class="form-note">We typically respond within 24-48 hours during business days.</p>
          </div>
        </form>
      </div>
    </section>

    <!-- PLAN YOUR VISIT -->
    <section class="section-padded">
      <div class="container-narrow">
        <div class="section-header-center">
          <span class="section-badge">Next Steps</span>
          <h2>Plan Your Visit</h2>
        </div>

        <div class="card-grid card-grid-3">
          
          <a href="/book.html" class="info-card">
            <div class="info-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <h3>Booking Page</h3>
            <p>Share the basics and continue by WhatsApp, email, or phone.</p>
            <span class="card-link">Go to Booking →</span>
          </a>

          <a href="/location.html" class="info-card">
            <div class="info-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3>Location Page</h3>
            <p>Use the clinic map, copy the address, and check landmark routes.</p>
            <span class="card-link">View Location →</span>
          </a>

          <a href="/process.html" class="info-card">
            <div class="info-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3>First-Visit Process</h3>
            <p>See what usually happens before, during, and after the first consultation.</p>
            <span class="card-link">Learn More →</span>
          </a>

        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="section-padded bg-dark text-light">
      <div class="container-narrow text-center">
        <h2>Ready to Begin?</h2>
        <p class="lead">
          Taking the first step is often the hardest part. We're here to make it easier.
        </p>
        <div class="cta-group">
          <a href="/book.html" class="button-primary button-large">Book an Appointment</a>
          <a href="tel:+919667863295" class="button-outline button-large">Call Us Now</a>
        </div>
      </div>
    </section>
</BaseLayout>
