---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- HERO -->
    <div class="shell">
      <div class="surface panel">
        <p class="eyebrow">Start here</p>
        <h1>Mental health tools , reliable and practical</h1>
        <p class="lead">
          These tools can support grounding, calming, and focus. They are meant to sit alongside professional care, not replace it.
        </p>
      </div>
    </div>

    <!-- TOOLS GRID -->
    <div class="shell section">
      <h2>Tools for Mental Well-Being</h2>
      
      <div class="card-grid">
        
        <!-- Tool 1: Guided Breathing -->
        <article class="card">
          <h3>Guided Breathing</h3>
          <p class="lead-mini">A simple way to calm the body when anxiety, overthinking, or restlessness builds up. Follow visual cues to regulate your breath.</p>
          <div class="cta-row">
            <a href="/guided-breathing/" class="button-primary">Start Exercise</a>
          </div>
        </article>

        <!-- Tool 2: Lateral Grounding -->
        <article class="card">
          <h3>Lateral Grounding</h3>
          <p class="lead-mini">Keep your head still. Follow the moving light with your eyes only. Helps reduce acute anxiety through bilateral stimulation.</p>
          <div class="cta-row">
            <a href="/eye-movement/" class="button-primary">Start Session</a>
          </div>
        </article>

        <!-- Tool 3: Fractal Grounding -->
        <article class="card">
          <h3>Fractal Grounding</h3>
          <p class="lead-mini">Tap to explode a fractal. Hold and move to swirl. Match your breath to the glow. Visual meditation for focus and calm.</p>
          <div class="cta-row">
            <a href="/hypnos-fractal/" class="button-primary">Launch Tool</a>
          </div>
        </article>

        <!-- Tool 4: River of Release -->
        <article class="card">
          <h3>River of Release</h3>
          <p class="lead-mini">Type a worry, watch it drift away on a leaf. A cognitive defusion exercise to help externalize and release anxious thoughts.</p>
          <div class="cta-row">
            <a href="/leaf-on-stream/" class="button-primary">Release a Worry</a>
          </div>
        </article>

        <!-- Tool 5: Butterfly Tapper -->
        <article class="card">
          <h3>Butterfly Tapper</h3>
          <p class="lead-mini">Alternate tapping with bilateral stimulation. Follow the comet, tap when ready. Helps process emotional logjams.</p>
          <div class="cta-row">
            <a href="/butterfly-tapper/" class="button-primary">Begin Tapping</a>
          </div>
        </article>

        <!-- Tool 6: Horizon Scan -->
        <article class="card">
          <h3>Horizon Scan</h3>
          <p class="lead-mini">Use smooth eye movements across an infinite horizon to lessen distress and expand your visual field during panic.</p>
          <div class="cta-row">
            <a href="/horizon-scan/" class="button-primary">Start Exercise</a>
          </div>
        </article>

      </div>
    </div>

    <!-- WHEN TO SEEK HELP -->
    <div class="shell section">
      <div class="surface panel">
        <h2>When to seek professional help</h2>
        <ul class="icon-list">
          <li>Symptoms lasting weeks or getting worse</li>
          <li>Sleep, appetite, or energy significantly affected</li>
          <li>Difficulty functioning at work, school, or home</li>
          <li>Frequent distress, panic, or emotional overwhelm</li>
          <li>Concerns about safety, self-harm, or substance use</li>
        </ul>
        <p>
          If you're unsure , that itself is a valid reason to consult a mental health professional.
        </p>
      </div>
    </div>

    <!-- CTA SECTION -->
    <div class="shell section">
      <div class="surface panel">
        <h2>Need more clarity?</h2>
        <p class="lead">
          Our clinicians are here to help you find the right support.
        </p>
        <div class="cta-row">
          <a href="/book.html" class="button-primary">Book a consultation</a>
          <a href="https://wa.me/919667863295" target="_blank" rel="noopener" class="button-ghost">
            Ask on WhatsApp
          </a>
          <a href="/faq.html" class="button-ghost">Read FAQ</a>
          <a href="/blog/index.html" class="button-ghost">Read blog articles</a>
        </div>
      </div>
    </div>
</BaseLayout>
