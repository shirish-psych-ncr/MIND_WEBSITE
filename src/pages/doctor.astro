---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout>
<!-- Hero Section -->
      <section class="hero hero-split">
        <div class="container hero-inner">
          <div class="hero-content">
            <span class="section-badge">Consultant Psychiatrist</span>
            <h1>Dr. Anita Sharma</h1>
            <p class="hero-lead">MBBS, DPM, MRCPsych (UK)</p>
            <p class="hero-text">
              Experienced psychiatrist dedicated to providing compassionate, evidence-based care for adults and children. 
              With international training and a holistic approach, Dr. Sharma helps patients navigate mental health challenges 
              with clarity and confidence.
            </p>
            <div class="cta-group">
              <a href="/book.html" class="btn btn-primary btn-large">Book Consultation</a>
              <a href="/services.html" class="btn btn-outline btn-large">View Services</a>
            </div>
          </div>
          <div class="hero-image">
            <img src="/res/doctor-profile.jpg" alt="Dr. Anita Sharma" class="hero-img" onerror="this.onerror=null; this.src="https://via.placeholder.com/500x600?text=Dr.+Anita+Sharma"" />
          </div>
        </div>
      </section>

      <!-- Introduction Section -->
      <section class="section section-light">
        <div class="container content-narrow">
          <h2>About Dr. Sharma</h2>
          <p>
            Dr. Anita Sharma is a Consultant Psychiatrist with over 15 years of experience in mental health care. 
            She completed her medical training at King George's Medical College, Lucknow, followed by specialized 
            psychiatry training at the Institute of Human Behaviour and Allied Sciences, Delhi.
          </p>
          <p>
            Her expertise extends internationally, having trained at the prestigious Maudsley Hospital in London, 
            where she gained valuable insights into cutting-edge psychiatric treatments and therapies. Dr. Sharma 
            believes in a patient-centered approach, combining medication management with psychotherapy to provide 
            comprehensive care tailored to each individual's needs.
          </p>
          <p>
            At Mind Grace Clinic, she leads a multidisciplinary team committed to reducing stigma and making 
            mental healthcare accessible, confidential, and effective for all patients.
          </p>
        </div>
      </section>

      <!-- Timeline Section: Education & Training -->
      <section class="section">
        <div class="container">
          <h2 class="section-title">Education & Training</h2>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-marker">
                <span class="step-number">01</span>
              </div>
              <div class="timeline-content">
                <h3>MBBS - Bachelor of Medicine, Bachelor of Surgery</h3>
                <p class="timeline-meta">King George's Medical College, Lucknow</p>
                <p>Foundation in medical sciences and clinical practice.</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-marker">
                <span class="step-number">02</span>
              </div>
              <div class="timeline-content">
                <h3>DPM - Diploma in Psychological Medicine</h3>
                <p class="timeline-meta">Institute of Human Behaviour and Allied Sciences, Delhi</p>
                <p>Specialized training in psychiatry and mental health disorders.</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-marker">
                <span class="step-number">03</span>
              </div>
              <div class="timeline-content">
                <h3>MRCPsych - Member of Royal College of Psychiatrists</h3>
                <p class="timeline-meta">Maudsley Hospital, London, UK</p>
                <p>Advanced international training in evidence-based psychiatric care.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Expertise Grid -->
      <section class="section section-light">
        <div class="container">
          <h2 class="section-title">Areas of Expertise</h2>
          <div class="expertise-grid">
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
              <span>Mood Disorders</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
              <span>Anxiety & Stress</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              <span>Adult ADHD</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              <span>Child Development</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span>Sleep Disorders</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              <span>Geriatric Psychiatry</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
              </svg>
              <span>Addiction Medicine</span>
            </div>
            <div class="expertise-tag">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              <span>Psychotherapy</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Philosophy Section -->
      <section class="section">
        <div class="container">
          <h2 class="section-title">Care Philosophy</h2>
          <div class="features-grid">
            <div class="feature-card">
              <div class="feature-icon">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
              </div>
              <h3>Whole Person Care</h3>
              <p>Treating the mind, body, and social context together for lasting wellness.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3>Evidence-Based</h3>
              <p>Using proven treatments backed by the latest scientific research.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <h3>Strict Confidentiality</h3>
              <p>Your privacy is paramount. All consultations are completely confidential.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="section-cta">
        <div class="container section-cta-center">
          <h2>Ready to Start Your Journey?</h2>
          <p>Take the first step towards better mental health with a confidential consultation.</p>
          <div class="cta-group">
            <a href="/book.html" class="btn btn-primary btn-large">Book Appointment</a>
            <a href="/contact.html" class="btn btn-outline btn-large">Contact Us</a>
          </div>
        </div>
      </section>
</BaseLayout>
