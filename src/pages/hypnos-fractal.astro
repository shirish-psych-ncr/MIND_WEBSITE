---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout>
<div class="progress"><div class="progress-bar" data-progress></div></div>

<div class="top-banner">
  In case of a medical emergency or immediate danger, please call 112 or visit the nearest hospital immediately.
</div>

<!-- HEADER -->
<header class="site-header">
  <div class="shell header-row">
    <a class="brand-wrap" href="/">
      <img class="logo" src="/res/Mind_Grace_Clinic_Logo.png" alt="Mind Grace Clinic logo" />
      <div>
        <p class="brand-kicker">Mind Grace Clinic</p>
        <p class="brand-name">Dr Anita Sharma MD</p>
      </div>
    </a>

    <nav class="nav">
      <a href="/about/">About</a>
      <a href="/conditions/">Conditions</a>
      <a href="/services/">Services</a>
      <a href="/process/">Process</a>
      <a href="/resources/">Resources</a>
      <a href="/blog/">Blog</a>
      <a href="/contact/">Contact</a>
    </nav>

    <div class="header-actions">
      <a class="button-outline" href="tel:+919667863295">Call</a>
      <a class="button" href="/book/">Book</a>
    </div>
  </div>
</header>

<main id="content" class="section shell stack" style="margin-top: 40px;">
  <section>
    <h1 style="font-weight: 600; font-size: 2.5rem; transition: 0.5s;">Grounding Fractal Tool</h1>
    <p class="lead" style="color: #64748b; font-size: 1.1rem; transition: 0.5s;">
      Tap to explode a fractal. Hold and move to swirl. Match your breath to the glow.
    </p>
  </section>

  <!-- FRACTAL TOOL -->
  <div class="tool-section">
    <canvas id="canvas"></canvas>
    <div class="breath-tag" id="breath-text">Centering...</div>
    <div id="min-btn" onclick="toggleZen()">⚙️</div>
    
    <div class="interface" id="ui">
        <div class="drawer">
            <div class="row">
                <label>Complexity</label>
                <input type="range" id="depth" min="3" max="8" value="5">
            </div>
            <div class="row">
                <label>Sensitivity</label>
                <input type="range" id="speed" min="5" max="80" value="30">
            </div>
            <div style="display:flex; gap:10px;">
                <button onclick="clearCanvas()" style="flex:1; padding:12px; border-radius:12px; background:white; font-weight:700; border:none; cursor:pointer;">CLEAR</button>
                <button id="haptic-toggle" onclick="toggleHaptic()" style="flex:1; padding:12px; border-radius:12px; background:none; border:1px solid white; color:white; font-size:0.7rem; cursor:pointer;">HAPTIC: ON</button>
            </div>
        </div>
    </div>
  </div>
</main>

<footer>
  <div class="shell">
    <p>&copy; 2024 Mind Grace Clinic. Guided tools are for support and do not replace clinical care.</p>
  </div>
</footer>

<style is:inline>
/* BASE CLINIC STYLES */
:root {
    --brand-primary: #0f172a;
    --brand-accent: #22d3ee;
    --surface: #ffffff;
    --text-main: #734155;
    --bg-dark: #010204;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Georgia, "Times New Roman", serif; color: var(--text-main); background: #f8fafc; line-height: 1.6; }

.shell { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
.stack > * + * { margin-top: 2rem; }

/* HEADER & BANNER */
.top-banner { background: #fee2e2; color: #991b1b; padding: 10px; font-size: 0.8rem; text-align: center; font-weight: 600; }
.site-header { background: #fff7fa; padding: 15px 0; border-bottom: 1px solid #e2e8f0; transition: opacity 0.8s; }
.header-row { display: flex; justify-content: space-between; align-items: center; }

.brand-wrap { display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit; }
.logo { height: 45px; width: auto; }
.brand-kicker { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--brand-accent); font-weight: 700; }
.brand-name { font-size: 1.1rem; font-weight: 600; }

nav a { margin: 0 10px; text-decoration: none; color: var(--text-main); font-size: 0.9rem; font-weight: 500; }
.button { background: var(--brand-primary); color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; }

/* FRACTAL TOOL CONTAINER */
.tool-section { 
    position: relative; 
    width: 100%; 
    height: 650px; 
    background: var(--bg-dark); 
    border-radius: 40px; 
    overflow: hidden; 
    margin: 40px 0;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
}

canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; cursor: crosshair; }

/* TOOL UI */
#min-btn {
    position: absolute; top: 25px; right: 25px; z-index: 101;
    width: 50px; height: 50px; border-radius: 50%;
    background: rgba(255,255,255,0.1); backdrop-filter: blur(15px);
    border: 1px solid rgba(255,255,255,0.2); color: white;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; pointer-events: auto; font-size: 1.2rem; transition: 0.3s;
}

.interface {
    position: absolute; z-index: 100; width: 100%; height: 100%;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 30px; pointer-events: none; transition: 0.5s ease-out;
}
.interface.collapsed { opacity: 0; transform: translateY(30px); }

.drawer {
    pointer-events: auto; background: rgba(10, 15, 25, 0.9);
    backdrop-filter: blur(30px); padding: 25px; border-radius: 30px;
    width: 100%; max-width: 380px; align-self: center;
}

.row { margin-bottom: 20px; text-align: left; }
label { display: block; font-size: 0.6rem; text-transform: uppercase; color: var(--brand-accent); letter-spacing: 2px; margin-bottom: 10px; }
input[type=range] { -webkit-appearance: none; width: 100%; height: 4px; background: #1e293b; border-radius: 10px; }
input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 22px; height: 22px; background: #fff; border-radius: 50%; border: 3px solid var(--brand-accent); }

.breath-tag {
    position: absolute; top: 40px; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.4); font-size: 0.7rem; letter-spacing: 5px; text-transform: uppercase; z-index: 5;
}

/* ZEN MODE HIDING */
.zen-active .site-header, .zen-active .top-banner, .zen-active footer, .zen-active h1, .zen-active .lead { 
    opacity: 0; pointer-events: none; 
}

footer { background: #f1f5f9; padding: 60px 0; margin-top: 60px; transition: opacity 0.8s; }
</style>

<script is:inline>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d', { alpha: false });
const breathText = document.getElementById('breath-text');
const ui = document.getElementById('ui');

let w, h, entities = [], isDown = false, hue = 180, haptic = true;

function resize() {
    w = canvas.width = canvas.parentElement.clientWidth;
    h = canvas.height = canvas.parentElement.clientHeight;
}
window.addEventListener('resize', resize);
resize();

function toggleZen() {
    document.body.classList.toggle('zen-active');
    ui.classList.toggle('collapsed');
    document.getElementById('min-btn').style.background = document.body.classList.contains('zen-active') ? 'var(--brand-accent)' : '';
}

class Star {
    constructor(x, y) {
        this.x = x; this.y = y; this.tx = x; this.ty = y;
        this.life = 1.0;
        this.d = parseInt(document.getElementById('depth').value);
    }
    update() {
        this.x += (this.tx - this.x) * 0.1;
        this.y += (this.ty - this.y) * 0.1;
        this.life -= 0.003;
    }
    draw(bs) {
        ctx.save();
        ctx.translate(this.x, this.y);
        for (let i = 0; i < 4; i++) {
            ctx.rotate(Math.PI / 2);
            this.step(0, 0, h * 0.18 * this.life, -Math.PI/2, this.d, bs);
        }
        ctx.restore();
    }
    step(x, y, l, a, d, bs) {
        if (d === 0) return;
        const x2 = x + Math.cos(a) * l;
        const y2 = y + Math.sin(a) * l;
        ctx.beginPath();
        ctx.moveTo(x, y);
        ctx.quadraticCurveTo(x + Math.cos(a+0.5) * l/2, y + Math.sin(a+0.5) * l/2, x2, y2);
        ctx.strokeStyle = `hsla(${(hue + d*15)%360}, 80%, 55%, ${this.life * d * 0.12 * bs})`;
        ctx.lineWidth = d * bs;
        ctx.stroke();
        const spr = 0.8 + (Math.sin(Date.now()*0.001)*0.2);
        this.step(x2, y2, l * 0.7, a - spr, d-1, bs);
        this.step(x2, y2, l * 0.7, a + spr, d-1, bs);
    }
}

const getPos = (e) => {
    const rect = canvas.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    return { x: clientX - rect.left, y: clientY - rect.top };
};

const start = (e) => {
    if (e.target.closest('.drawer') || e.target.id === 'min-btn') return;
    isDown = true;
    const p = getPos(e);
    entities.push(new Star(p.x, p.y));
    if(haptic && navigator.vibrate) navigator.vibrate(15);
};

const move = (e) => {
    if (!isDown) return;
    const p = getPos(e);
    if (entities.length > 0) {
        entities[entities.length-1].tx = p.x;
        entities[entities.length-1].ty = p.y;
    }
};

canvas.addEventListener('mousedown', start);
window.addEventListener('mousemove', move);
window.addEventListener('mouseup', () => isDown = false);
canvas.addEventListener('touchstart', start, {passive:false});
window.addEventListener('touchmove', move, {passive:false});
window.addEventListener('touchend', () => isDown = false);

function animate() {
    hue += 0.2;
    const bCycle = (Math.sin(Date.now() / 1500) + 1) / 2;
    const bScale = 0.5 + (bCycle * 0.5);
    breathText.innerText = bCycle > 0.8 ? "Hold" : (Math.cos(Date.now()/1500) > 0 ? "Inhale" : "Exhale");
    
    ctx.fillStyle = `rgba(1, 2, 4, 0.15)`;
    ctx.fillRect(0, 0, w, h);
    
    entities.forEach((p, i) => {
        p.update(); p.draw(bScale);
        if (p.life <= 0) entities.splice(i, 1);
    });
    
    if(haptic && bCycle > 0.98 && navigator.vibrate) navigator.vibrate(8);
    requestAnimationFrame(animate);
}

function clearCanvas() { entities = []; ctx.fillStyle = "#010204"; ctx.fillRect(0,0,w,h); }
function toggleHaptic() { haptic = !haptic; document.getElementById('haptic-toggle').innerText = haptic ? "HAPTIC: ON" : "HAPTIC: OFF"; }

animate();
</script>
</BaseLayout>
