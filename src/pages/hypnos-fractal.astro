---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<section>
        <h1>Grounding Fractal Tool</h1>
        <p class="lead">
          Tap to explode a fractal. Hold and move to swirl. Match your breath to the glow.
        </p>
      </section>

      <!-- FRACTAL TOOL -->
      <div class="tool-section">
        <canvas id="canvas"></canvas>
        <div class="breath-tag" id="breath-text">Centering...</div>
        <div id="min-btn" onclick="toggleZen()">⚙️</div>
        
        <div class="interface" id="fractal-ui">
            <div class="drawer">
                <div class="row">
                    <label>Complexity</label>
                    <input type="range" id="depth" min="3" max="8" value="5">
                </div>
                <div class="row">
                    <label>Sensitivity</label>
                    <input type="range" id="speed" min="5" max="80" value="30">
                </div>
                <div>
                    <button onclick="clearCanvas()">CLEAR</button>
                    <button id="haptic-toggle" onclick="toggleHaptic()">HAPTIC: ON</button>
                </div>
            </div>
        </div>
      </div>
</BaseLayout>
