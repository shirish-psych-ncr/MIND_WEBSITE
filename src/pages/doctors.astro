---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
<!-- Intro Banner -->
        <section class="team-intro-banner">
            <div class="container">
                <h1 style="color: white; margin-bottom: 1rem; font-size: clamp(2rem, 5vw, 3rem);">Comprehensive Care Under One Roof</h1>
                <p style="font-size: 1.2rem; max-width: 800px; margin: 0 auto; line-height: 1.6;">
                    We offer both <strong>psychiatric medical care</strong> and <strong>psychological therapy services</strong>. 
                    Whether you need medication management, deep therapy, or child development support, 
                    our multidisciplinary team is here for you.
                </p>
                <div class="jump-buttons">
                    <a href="#psychiatrist" class="jump-btn">🩺 See Psychiatrist</a>
                    <a href="#psychologist" class="jump-btn">🧠 See Psychologist</a>
                </div>
            </div>
        </section>

        <!-- Service Comparison -->
        <section class="section">
            <div class="container">
                <div class="content-narrow" style="text-align: center; margin-bottom: 3rem;">
                    <span class="section-badge">Understanding Our Roles</span>
                    <h2 style="margin-top: 1rem;">How Dr. Anita (Psychiatrist) and Dr. Sana (Psychologist) Can Help You</h2>
                    <p class="lead" style="margin-top: 1rem; color: var(--text-muted);">Both professionals work together to provide integrated, holistic care.</p>
                </div>
                
                <div class="service-comparison">
                    <div class="comparison-card">
                        <h3><span>🩺</span> Psychiatrist (Dr. Anita)</h3>
                        <p><strong>Medical Doctor (MD)</strong> specializing in mental health. Can prescribe medication and manage complex biological aspects of mental illness.</p>
                        <ul style="padding-left: 1.2rem; line-height: 2; margin: 1.5rem 0;">
                            <li>Diagnoses medical conditions</li>
                            <li>Prescribes & manages medication</li>
                            <li>Treats complex biological issues</li>
                            <li>Handles severe mental illness</li>
                            <li>Provides medical certificates</li>
                            <li>Manages hospital admissions</li>
                        </ul>
                        <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-muted); background: var(--bg-soft); padding: 1rem; border-radius: var(--radius-sm);">
                            <strong>Best for:</strong> Medication needs, severe depression, bipolar disorder, schizophrenia, addiction medical management, complex cases requiring medical intervention.
                        </p>
                    </div>
                    
                    <div class="comparison-card">
                        <h3><span>🧠</span> Psychologist (Dr. Sana)</h3>
                        <p><strong>Clinical Psychologist (M.Phil)</strong> specializing in psychotherapy and psychological testing. Provides talk therapy and behavioral interventions.</p>
                        <ul style="padding-left: 1.2rem; line-height: 2; margin: 1.5rem 0;">
                            <li>Provides psychotherapy & counseling</li>
                            <li>Conducts psychological testing</li>
                            <li>Teaches coping skills & strategies</li>
                            <li>Child development & behavior</li>
                            <li>Trauma processing & talk therapy</li>
                            <li>Learning disability assessment</li>
                        </ul>
                        <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-muted); background: var(--bg-soft); padding: 1rem; border-radius: var(--radius-sm);">
                            <strong>Best for:</strong> Talk therapy, anxiety management, child behavioral issues, learning disabilities, relationship counseling, trauma processing, skill-building.
                        </p>
                    </div>

                    <div class="comparison-card common-services">
                        <h3 style="justify-content: center; color: var(--primary);"><span>🤝</span> Common Services (Both Specialists)</h3>
                        <p style="margin-bottom: 1.5rem;">Many patients benefit from seeing <strong>both</strong> specialists for integrated, comprehensive care.</p>
                        <div style="display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; max-width: 700px; margin: 0 auto;">
                            <span class="service-tag">Anxiety & Depression</span>
                            <span class="service-tag">Stress Management</span>
                            <span class="service-tag">ADHD Support</span>
                            <span class="service-tag">Sleep Issues</span>
                            <span class="service-tag">Trauma & PTSD</span>
                            <span class="service-tag">Family Counseling</span>
                            <span class="service-tag">OCD Treatment</span>
                            <span class="service-tag">Grief & Loss</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dr. Anita Sharma Section -->
        <section id="psychiatrist" class="doctor-section">
            <div class="container">
                <div class="doctor-profile-grid">
                    <div class="doctor-image-frame">
                        <img src="./assets/images/dr-anita-sharma.jpg" alt="Dr. Anita Sharma - Psychiatrist" onerror="this.style.display='none'; this.nextElementSibling.style.display='block'">
                        <svg style="display:none; width:100%; height:100%; background:linear-gradient(135deg, #f0f4f8, #e2e8f0); color:#64748b;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-label="Placeholder image for Dr. Anita Sharma">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" fill="white" stroke="none"></rect>
                            <circle cx="12" cy="8" r="4" fill="#cbd5e1" stroke="none"></circle>
                            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" fill="#cbd5e1" stroke="none"></path>
                            <text x="12" y="16" text-anchor="middle" font-size="4" fill="#475569" stroke="none" font-weight="bold">MD</text>
                        </svg>
                    </div>
                    
                    <div>
                        <span class="section-badge">Founder & Director</span>
                        <h2 style="font-size: clamp(2rem, 4vw, 2.5rem); margin: 0.5rem 0; color: var(--text-dark);">Dr. Anita Sharma</h2>
                        <p class="lead" style="color: var(--primary); font-weight: 600; font-size: 1.2rem;">MBBS, MD (Psychiatry) | 14+ Years Experience</p>
                        
                        <div class="doctor-credentials">
                            <h4 style="margin-top: 0; color: var(--text-dark);">Registrations & Affiliations</h4>
                            <ul class="credential-list">
                                <li><span>Medical Council of India</span> <strong>11-40210</strong></li>
                                <li><span>Healthcare Professionals Registry</span> <strong>HPR ID: 71-2147-5815-3754</strong></li>
                                <li><span>Delhi Medical Council</span> <strong>Registered</strong></li>
                            </ul>
                        </div>

                        <div class="quote-box">
                            <p style="margin: 0; font-size: 1.1rem; line-height: 1.6;">"For me, transforming people's lives is a calling. I am passionate about what I do. For me, outcomes are important."</p>
                        </div>

                        <h3 style="color: var(--primary);">Professional Summary</h3>
                        <p style="line-height: 1.8;">Experienced Psychiatrist uniquely integrating <strong>adult mental health care</strong> and <strong>child developmental support</strong> under one roof. Combines rigorous academic training from premier national institutions (AIIMS, IHBAS) with compassionate, outcome-focused care. Registered with the Medical Council of India and listed on India's Healthcare Professionals Registry.</p>

                        <h3 style="color: var(--primary); margin-top: 2rem;">Education & Training</h3>
                        <ul class="check-list" style="line-height: 2;">
                            <li><strong>M.D. (Psychiatry)</strong> - Guru Gobind Singh Medical College and Hospital, Faridkot</li>
                            <li><strong>M.B.B.S.</strong> - Universal College of Medical Sciences, Nepal</li>
                            <li><strong>Senior Residency Training</strong> - AIIMS Rishikesh & IHBAS New Delhi</li>
                        </ul>

                        <h3 style="color: var(--primary); margin-top: 2rem;">Adult Mental Health Services (Mind Grace Clinic)</h3>
                        <div class="service-tags">
                            <span class="service-tag">Depression & Emotional Wellness</span>
                            <span class="service-tag">Anxiety, Stress & Panic</span>
                            <span class="service-tag">Bipolar Disorder</span>
                            <span class="service-tag">Schizophrenia Care</span>
                            <span class="service-tag">Alcohol & Substance Addiction</span>
                            <span class="service-tag">Smartphone/Internet/Gaming Addiction</span>
                            <span class="service-tag">Relationship & Marriage Counseling</span>
                            <span class="service-tag">Sleep Disorder Management</span>
                            <span class="service-tag">ADHD & PTSD Support</span>
                        </div>

                        <h3 style="color: var(--primary); margin-top: 2rem;">Hospital Panel Affiliations</h3>
                        <ul class="hospital-list">
                            <li>Naveen Hospital, Alpha-2, Greater Noida</li>
                            <li>Green City Hospital, Delta-1, Greater Noida</li>
                            <li>Sahdeo Hospital, Ansal Golf Link, Greater Noida</li>
                        </ul>

                        <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
                            <a href="./book.html" class="btn btn-primary">Book Appointment with Dr. Anita</a>
                            <a href="tel:+919667863295" class="btn btn-outline">📞 Call +91 96678 63295</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dr. Sana Firdous Section -->
        <section id="psychologist" class="doctor-section alt-bg">
            <div class="container">
                <div class="doctor-profile-grid">
                    <div class="doctor-image-frame" style="background: linear-gradient(135deg, #1a202c, #2d3748);">
                        <!-- Dark SVG Placeholder as requested - to be replaced with photo later -->
                        <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="#718096" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-label="Placeholder image for Dr. Sana Firdous">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" fill="#2d3748" stroke="none"></rect>
                            <circle cx="12" cy="8" r="4" fill="#4a5568" stroke="none"></circle>
                            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" fill="#4a5568" stroke="none"></path>
                            <text x="12" y="15" text-anchor="middle" font-size="3" fill="#cbd5e1" font-family="sans-serif" font-weight="bold">M.Phil</text>
                        </svg>
                    </div>
                    
                    <div>
                        <span class="section-badge" style="background: var(--secondary);">Consultant Clinical Psychologist</span>
                        <h2 style="font-size: clamp(2rem, 4vw, 2.5rem); margin: 0.5rem 0; color: var(--text-dark);">Dr. Sana Firdous</h2>
                        <p class="lead" style="color: var(--secondary); font-weight: 600; font-size: 1.2rem;">M.Phil Clinical Psychology | RCI No. A82170 | 7+ Years Experience</p>
                        
                        <div class="doctor-credentials alt">
                            <h4 style="margin-top: 0; color: var(--text-dark);">Credentials & Current Role</h4>
                            <ul class="credential-list">
                                <li><span>RCI Registration</span> <strong>A82170</strong></li>
                                <li><span>Experience</span> <strong>7+ Years</strong></li>
                                <li><span>Current Position</span> <strong>Sharda Hospital, Greater Noida</strong></li>
                            </ul>
                        </div>

                        <h3 style="color: var(--secondary);">Professional Background</h3>
                        <p style="line-height: 1.8;">Clinical Psychologist with over seven years of experience in psychodiagnostic assessments, psychotherapy, and child/adolescent mental health. Specializes in neurodevelopmental disorders, cognitive evaluations, and evidence-based psychological assessment. Currently serves as Consultant Clinical Psychologist and Clinical Child Psychologist at Sharda Hospital, Greater Noida.</p>

                        <h3 style="color: var(--secondary); margin-top: 2rem;">Specializations</h3>
                        <div class="service-tags">
                            <span class="service-tag" style="border-color: var(--secondary);">Child Psychology</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Psychotherapy (CBT, DBT)</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Psychodiagnostic Testing</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Neurodevelopmental Disorders</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Behavioral Disorders</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Cognitive Evaluation</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Trauma Therapy</span>
                            <span class="service-tag" style="border-color: var(--secondary);">Family Counseling</span>
                        </div>

                        <h3 style="color: var(--secondary); margin-top: 2rem;">Therapeutic Services (Aasha & Mind Grace)</h3>
                        <ul class="check-list" style="line-height: 2;">
                            <li><strong>Child Development:</strong> Early intervention, speech delays, autism support, ADHD behavioral management, sensory integration issues.</li>
                            <li><strong>Psychotherapy:</strong> CBT, DBT, and supportive therapy for anxiety, depression, trauma, and relationship issues.</li>
                            <li><strong>Psychological Assessment:</strong> IQ testing, personality assessments, specific learning disability evaluations, neuropsychological screening.</li>
                            <li><strong>Family Support:</strong> Parenting guidance, couple therapy, family conflict resolution, psychoeducation.</li>
                        </ul>

                        <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
                            <a href="./book.html" class="btn btn-primary" style="background: var(--secondary); border-color: var(--secondary);">Book Session with Dr. Sana</a>
                            <a href="tel:+919667863295" class="btn btn-outline">📞 Call +91 96678 63295</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Philosophy Section -->
        <section class="section bg-blush">
            <div class="container">
                <div class="content-narrow" style="text-align: center;">
                    <span class="section-badge">Our Philosophy</span>
                    <h2 style="margin-top: 1rem;">Whole-Family, Integrated Care</h2>
                    <p class="lead" style="margin-top: 1rem; font-size: 1.2rem; line-height: 1.8;">
                        "We are here to help you solve serious problems with compassion and a non-judgmental approach.<br>
                        At <strong>Mind Grace</strong>, we restore balance for adults carrying life's weight.<br>
                        At <strong>Aasha</strong>, we nurture potential for children finding their path.<br>
                        Together, we support whole families – because when a child thrives, parents breathe easier; when parents heal, children feel safe."
                    </p>
                    <p style="margin-top: 1.5rem; font-weight: 600; color: var(--primary);">— Dr. Anita Sharma, Founder</p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="section-cta">
            <div class="container">
                <div class="cta-content">
                    <h2>Not sure who to see?</h2>
                    <p style="font-size: 1.1rem; max-width: 700px; margin: 1rem auto 2rem;">Our front desk team can help guide you to the right specialist based on your specific needs. Many patients benefit from coordinated care between both professionals.</p>
                    <div class="cta-group">
                        <a href="./contact.html" class="btn btn-light">Contact Us for Guidance</a>
                        <a href="./process.html" class="btn btn-outline-light">Learn How It Works</a>
                    </div>
                </div>
            </div>
        </section>
</BaseLayout>
