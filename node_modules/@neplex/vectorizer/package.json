{
  "name": "@neplex/vectorizer",
  "version": "0.1.0",
  "description": "Node.js library to convert raster images to svg",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": "cli/index.mjs",
  "browser": "browser.js",
  "files": [
    "index.js",
    "index.d.ts",
    "js-bindings.js",
    "js-bindings.d.ts",
    "browser.js",
    "cli/index.mjs"
  ],
  "author": "Twilight <hello@twlite.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/neplextech/vectorizer"
  },
  "license": "MIT",
  "keywords": [
    "vectorizer",
    "raster-to-svg",
    "image-tracing",
    "svg-optimization",
    "nodejs",
    "rust",
    "napi"
  ],
  "napi": {
    "binaryName": "vectorizer",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "i686-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf",
      "aarch64-apple-darwin",
      "aarch64-linux-android",
      "x86_64-unknown-freebsd",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "armv7-linux-androideabi",
      "wasm32-wasip1-threads"
    ],
    "constEnum": false
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --expose-gc --import @oxc-node/core/register benchmark/bench.ts",
    "build": "node scripts/build.js --release",
    "build:wasm": "node scripts/build.js --release --target wasm32-wasip1-threads",
    "build:debug": "node scripts/build.js",
    "build:debug:wasm": "node scripts/build.js --target wasm32-wasip1-threads",
    "example": "node --import @oxc-node/core/register example/anime-girl.ts",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "generate-exports": "node scripts/postbuild.js",
    "lint": "oxlint .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "preversion": "napi build --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@napi-rs/image": "^1.12.0",
    "@napi-rs/wasm-runtime": "^1.1.4",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/node": "^25.9.1",
    "ava": "^8.0.0",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "imagetracerjs": "^1.2.6",
    "lint-staged": "^17.0.0",
    "mitata": "^1.0.34",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "potrace": "^2.1.8",
    "prettier": "^3.6.2",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "packageManager": "yarn@4.15.0",
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "optionalDependencies": {
    "@neplex/vectorizer-win32-x64-msvc": "0.1.0",
    "@neplex/vectorizer-darwin-x64": "0.1.0",
    "@neplex/vectorizer-linux-x64-gnu": "0.1.0",
    "@neplex/vectorizer-linux-x64-musl": "0.1.0",
    "@neplex/vectorizer-linux-arm64-gnu": "0.1.0",
    "@neplex/vectorizer-win32-ia32-msvc": "0.1.0",
    "@neplex/vectorizer-linux-arm-gnueabihf": "0.1.0",
    "@neplex/vectorizer-darwin-arm64": "0.1.0",
    "@neplex/vectorizer-android-arm64": "0.1.0",
    "@neplex/vectorizer-freebsd-x64": "0.1.0",
    "@neplex/vectorizer-linux-arm64-musl": "0.1.0",
    "@neplex/vectorizer-win32-arm64-msvc": "0.1.0",
    "@neplex/vectorizer-android-arm-eabi": "0.1.0",
    "@neplex/vectorizer-wasm32-wasi": "0.1.0"
  }
}