name: 🛡️ AI Containment & Static CI/CD Fortress

on:
  push:
    branches: ["main"]
  pull_request:
    branches: ["main"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  # ============================================
  # JOB 1: The AI Sanitizer (Native Code Hygiene)
  # ============================================
  ai-sanitizer:
    name: 🧹 AI Laziness & Visual Trap Sanitizer
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Codebase
        uses: actions/checkout@v4

      - name: 🚨 Detect AI Placeholders & Truncation
        run: |
          echo "### 🚨 AI Placeholder Scan" >> $GITHUB_STEP_SUMMARY
          TARGET_PATTERNS="TODO|FIXME|placeholder|insert code|write code|code goes here|rest of the code|logic here"
          TRUNCATION_PATTERNS="\.\.\.|---"
          
          if grep -riE "$TARGET_PATTERNS|$TRUNCATION_PATTERNS" --include=\*.{html,css,js,xml} .; then
            echo "- **CRITICAL FAILURE:** The AI left unfinished structural placeholders or truncated code." >> $GITHUB_STEP_SUMMARY
            exit 1
          fi
          echo "- ✅ Codebase is free of lazy placeholders." >> $GITHUB_STEP_SUMMARY

      - name: 🎨 CSS Contrast & Architecture Enforcement
        run: |
          echo "### 🎨 CSS Visual & Structural Audit" >> $GITHUB_STEP_SUMMARY
          python3 -c "
          import re, glob, sys
          
          failed = False
          for f in glob.glob('**/*.css', recursive=True):
              content = open(f).read().lower().replace(' ', '').replace('\n', '')
              
              # 1. Blind Contrast Collisions (Light text on Light background)
              light_text = ['color:#fff', 'color:#ffffff', 'color:white', 'color:#f0f0f0', 'color:#eee']
              light_bg = ['background-color:#fff', 'background-color:#ffffff', 'background:white', 'background:#fff', 'background:#f0f0f0', 'background:#eee', 'background-color:#eee']
              
              has_light_text = any(t in content for t in light_text)
              has_light_bg = any(b in content for b in light_bg)
              
              if has_light_text and has_light_bg:
                  print(f'::error file={f}:: Visual Trap: Light text on light background detected.')
                  failed = True
                  
              # 2. 'Z-Index Wars' and '!important' Abuse
              important_count = content.count('!important')
              if important_count > 3:
                  print(f'::error file={f}:: Architecture Violation: Found {important_count} uses of !important.')
                  failed = True

          if failed:
              sys.exit(1)
          "
          echo "- ✅ CSS architecture passes visual and structural checks." >> $GITHUB_STEP_SUMMARY

      - name: 📡 Strict RSS / XML Compilation Check
        run: |
          echo "### 📡 RSS/XML Structural Integrity" >> $GITHUB_STEP_SUMMARY
          python3 -c "
          import glob, xml.etree.ElementTree as ET, sys
          failed = False
          for f in glob.glob('**/*.xml', recursive=True):
              try:
                  ET.parse(f)
              except Exception as e:
                  print(f'::error file={f}:: XML Parse Error: {e}')
                  failed = True
          if failed:
              sys.exit(1)
          "
          echo "- ✅ All XML/RSS feeds are structurally sound." >> $GITHUB_STEP_SUMMARY

  # ============================================
  # JOB 2: Deep Structural & Asset Inspector
  # ============================================
  deep-inspector:
    name: 🔬 W3C, Metadata & Asset Inspector
    runs-on: ubuntu-latest
    needs: ai-sanitizer
    steps:
      - name: Checkout Codebase
        uses: actions/checkout@v4

      # INSPIRED BY: anishathalye/proof-html
      # This single action replaces 5 different tools. It validates HTML/CSS, 
      # checks OpenGraph metadata, verifies favicons, and enforces HTTPS.
      - name: 🏗️ Deep Structural & Metadata Inspection
        uses: anishathalye/proof-html@v2.2.3
        with:
          directory: ./
          check_html: true
          check_css: true
          check_external_hash: true   # Catches broken #anchor links (e.g., href="#contact" missing)
          check_opengraph: true       # Catches broken OG images/URLs for social sharing
          check_favicon: true         # Ensures favicon exists and is valid
          enforce_https: true         # Forces AI to use https:// instead of http://
          # Ignore noisy external domains that rate-limit or block CI runners
          ignore_url: |
            https://twitter.com
            https://x.com
            https://facebook.com

      # INSPIRED BY: lycheeverse/lychee-action & modernweb-dev/check-html-links-action
      # While proof-html checks links, Lychee is written in Rust and is exponentially faster 
      # at verifying that local assets (<img>, <script>, <link>) actually exist in the filesystem.
      - name: 🔗 Local Asset & External Link Annihilation
        uses: lycheeverse/lychee-action@v2
        with:
          args: >
            --verbose
            --no-progress
            --exclude-mail
            --accept 200,204,301,302
            --exclude-path 'node_modules'
            './**/*.html'
            './**/*.css'
            './**/*.xml'
          fail: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  # ============================================
  # JOB 3: Immutable CD Deployment Layer
  # ============================================
  deploy:
    name: 🚀 Production Deployment
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    needs: [ai-sanitizer, deep-inspector]
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Initialize GitHub Pages Infrastructure
        id: pages
        uses: actions/configure-pages@v5

      - name: Package Validated Assets
        uses: actions/upload-pages-artifact@v3
        with:
          path: '.' # Assumes root directory. Change to './dist' if using a build step.

      - name: Commit Live to Pages Pipeline
        id: deployment
        uses: actions/deploy-pages@v4
